# RepCon Voice Agent - Environment Variables Template
# Copy this to .env and fill in your values

# App
APP_NAME=RepCon Voice Agent
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://repcon:repcon123@postgres:5432/repcon
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://redis:6379

# JWT Auth
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Ollama (LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+91xxxxxxxxxx

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'
GOOGLE_SHEETS_ID=your-spreadsheet-id

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Optional: Sentry (Error Tracking)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Optional: Cloud Provider (AWS/GCP)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
